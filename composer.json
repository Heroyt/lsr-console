{
  "name": "lsr/console",
  "description": "Laser framework core - Console helpers",
  "version": "0.1.4",
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.laserliga.cz"
    }
  ],
  "scripts": {
    "test": "XDEBUG_MODE=coverage ./vendor/bin/phpunit",
    "docs": "doxygen",
    "phpstan": "./vendor/bin/phpstan",
    "phpcs": "./vendor/bin/phpcs",
    "cs": "./vendor/bin/phpcs",
    "phpcbf": "./vendor/bin/phpcbf",
    "cbf": "./vendor/bin/phpcbf"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "phpunit/phpunit": "^12",
    "phpstan/phpstan": "^2.0",
    "phpstan/extension-installer": "^1.2",
    "squizlabs/php_codesniffer": "^4",
    "nette/di": "^3.2"
  },
  "autoload": {
    "psr-4": {
      "Lsr\\Console\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Tomáš Vojík",
      "email": "vojik@wboy.cz"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.4",
    "symfony/console": "^8|^7"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "extra": {
  }
}
